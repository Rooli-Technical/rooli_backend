generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String     @id @default(cuid())
  email                String     @unique
  password             String? // Optional for OAuth users
  firstName            String?
  lastName             String?
  avatarId             String?    @unique
  avatar               MediaFile? @relation("UserAvatar", fields: [avatarId], references: [id], onDelete: SetNull)
  userType             UserType   @default(INDIVIDUAL)
  timezone             String?    @default("Africa/Lagos")
  isOnboardingComplete Boolean    @default(false)

  lastVerificationEmailSentAt DateTime?

  // Tracks which Workspace (Client) the user was looking at last
  lastActiveWorkspaceId String?
  lastActiveWorkspace   Workspace? @relation("UserLastActiveWorkspace", fields: [lastActiveWorkspaceId], references: [id], onDelete: SetNull)

  // Email verification
  isEmailVerified Boolean @default(false)
  refreshToken    String?

  passwordResetOtp        String? // Stores the hashed OTP
  passwordResetOtpExpires DateTime?

  // Security
  loginAttempts       Int       @default(0)
  lockedUntil         DateTime?
  lastPasswordChange  DateTime?
  refreshTokenVersion Int       @default(0)

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  lastActiveAt DateTime?

  mediaFiles              MediaFile[]
  organizationMemberships OrganizationMember[] @relation("UserOrganizationMemberships")

  sentInvitations Invitation[] @relation("UserSentInvitations")

  // messages                 Message[]
  // notifications            NotificationEntity[]
  ContentTemplate    ContentTemplate[]
  Post               Post[]
  approvalsRequested PostApproval[]         @relation("ApprovalRequester")
  approvalsGiven     PostApproval[]         @relation("ApprovalApprover")
  auditLogs          AuditLog[]
  favoriteTemplates  UserFavoriteTemplate[]

  comments Comment[]

  assignedTickets Ticket[]        @relation("TicketAssignee")
  ticketComments  TicketComment[]
  adminSessions   AdminSession[]  @relation("AdminSessions")
  ipWhitelist     IpWhitelist[]   @relation("AdminIpWhitelist")

  @@index([email, deletedAt])
  @@index([createdAt])
  @@index([lastActiveAt])
}

model Organization {
  id               String             @id @default(cuid())
  name             String
  email            String?
  timezone         String             @default("Africa/Lagos") //All scheduling logic (cron jobs, "best time to post" AI) defaults to this timezone.
  slug             String             @unique
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  isActive         Boolean            @default(true)
  // Branding
  agencyLogoUrl    String?
  agencyColor      String?
  // Billing & Status
  billingEmail     String?
  billingCountry   String             @default("NG")
  currency         String             @default("NGN")
  status           OrganizationStatus @default(PENDING_PAYMENT)
  totalCreditsUsed Int                @default(0)

  members   OrganizationMember[]
  roles     Role[]
  invites   Invitation[]
  auditLogs AuditLog[]

  workspaces        Workspace[]
  socialConnections SocialConnection[]

  // conversations        Conversation[]
  // notifications        NotificationEntity[]
  webhookLogs     WebhookLog[]
  PostingSchedule PostingSchedule[]
  ContentTemplate ContentTemplate[]

  aigeneration AiGeneration[]

  subscriptionGateway SubscriptionGateway @default(PAYSTACK)

  subscription Subscription? // 1-to-1 relation
  transactions Transaction[] // Payment history

  settings Json?

  publishingMetrics PublishingMetric[]
}

model Workspace {
  id       String @id @default(cuid())
  name     String // e.g. "Coca Cola Account" or "Personal Brand"
  slug     String // unique-per-org logic needed in app code, or globally unique
  timezone String @default("UTC") // For scheduling posts

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  socialProfiles SocialProfile[]

  // Posts belong to a Workspace
  posts        Post[]
  mediaFolders MediaFolder[]
  mediaFiles   MediaFile[]

  usersActiveHere User[] @relation("UserLastActiveWorkspace")

  // --- THE "CLIENT LABEL" FEATURES ---
  // These fields are only used if the Plan allows "clientLabels"
  agencyClientName    String?
  agencyClientStatus  String? // "Active", "Onboarding", "Churned"
  agencyClientContact String? // "Jane Doe (jane@coke.com)"
  agencyClientColor   String? // "#FF0000" (To color-code the dashboard card)

  queueSlots QueueSlot[]
  campaigns  Campaign[]

  aigeneration AiGeneration[]
  brandKit     BrandKit?

  members       WorkspaceMember[]
  invitations   Invitation[]
  notifications Notification[]

  comments Comment[]

  ticketCounter Int      @default(0)
  tickets       Ticket[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, slug])
}

model OrganizationMember {
  id             String @id @default(cuid())
  organizationId String
  userId         String
  roleId         String

  // Invitation / lifecycle metadata
  invitedByUserId String?
  joinedAt        DateTime @default(now())

  lastActiveAt DateTime?

  isActive Boolean @default(true)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation("UserOrganizationMemberships", fields: [userId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id])

  workspaceMemberships WorkspaceMember[]
  auditLogsAsActor     AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, userId])
  @@index([lastActiveAt])
}

model WorkspaceMember {
  id          String @id @default(cuid())
  workspaceId String

  memberId String

  workspace Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  member    OrganizationMember? @relation(fields: [memberId], references: [id], onDelete: Cascade)

  roleId String?
  role   Role?   @relation("WorkspaceRole", fields: [roleId], references: [id])

  assignedConversations InboxConversation[]     @relation("ConversationAssignee")
  readStates            ConversationReadState[]

  notifications Notification[]

  comments Comment[]
  messages InboxMessage[]

  isActive Boolean @default(true)

  submittedTickets Ticket[] @relation("TicketRequester")

  createdAt DateTime @default(now())

  @@unique([workspaceId, memberId])
  @@index([memberId])
  @@index([workspaceId])
}

model Invitation {
  id             String @id @default(cuid())
  email          String
  token          String @unique
  organizationId String

  roleId String

  workspaceId String? // null = org-wide invite

  inviterId String
  inviter   User   @relation("UserSentInvitations", fields: [inviterId], references: [id], onDelete: Cascade)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id])
  workspace    Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  status InvitationStatus @default(PENDING)

  acceptedAt DateTime?
  revokedAt  DateTime?
  declinedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@unique([email, organizationId, workspaceId])
  @@index([organizationId, status])
  @@index([email])
}

model SocialConnection {
  id             String           @id @default(cuid())
  organizationId String
  platform       Platform // FACEBOOK, LINKEDIN, TWITTER
  status         ConnectionStatus @default(CONNECTED)

  // USER CREDENTIALS (The "Master Key")
  // Used to refresh tokens and fetch list of pages
  platformUserId   String // The generic User ID (e.g. FB User ID)
  platformUsername String?

  accessToken    String    @db.Text // Encrypted
  refreshToken   String?   @db.Text // Encrypted  //twitter access secret
  tokenExpiresAt DateTime?

  // Relations
  organization Organization    @relation(fields: [organizationId], references: [id])
  profiles     SocialProfile[] // One Login -> Many Pages

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, platform, platformUserId]) // Prevent duplicate logins
  @@index([organizationId])
}

model SocialProfile {
  id                 String @id @default(cuid())
  workspaceId        String
  socialConnectionId String // Link back to the parent login

  platform Platform

  facebookPageId String?

  platformId String // The Page ID / IG Business ID
  name       String // "Nike Official"
  username   String? // "@nike"
  picture    String?

  followerCount Int @default(0)

  status ConnectionStatus @default(CONNECTED)

  // PAGE CREDENTIALS (The "Room Key")
  // Specific token to post to THIS page. 
  // For FB/IG: This is the Page Access Token.
  // For X/LinkedIn: Often a copy of the User Token.
  accessToken String? @db.Text

  type SocialProfileType

  // Relations
  workspace  Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  connection SocialConnection @relation(fields: [socialConnectionId], references: [id], onDelete: Cascade)

  // The posts scheduled for this specific profile
  postDestinations PostDestination[]

  accountAnalytics AccountAnalytics[]

  // Analytics for this specific profile
  //dailyAnalytics     AccountAnalytics[]

  isActive Boolean @default(true)

  webhookRoutingUserId String?

  inboxConversations InboxConversation[]
  comments           Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, platform, platformId])
  @@index([workspaceId])
}

// ==========================================
// 1. CAMPAIGNS & ORGANIZATION
// ==========================================

model Campaign {
  id          String         @id @default(cuid())
  workspaceId String
  name        String
  description String?
  color       String?        @default("#1877F2") // For Calendar UI
  startDate   DateTime
  endDate     DateTime?
  status      CampaignStatus @default(ACTIVE)

  posts Post[]

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, status])
}

// ==========================================
// 2. THE POSTING ENGINE
// ==========================================

model Post {
  id          String  @id @default(cuid())
  workspaceId String
  authorId    String?

  content String? @db.Text

  media PostMedia[]

  contentType ContentType @default(POST) // REEL, STORY, THREAD, POST
  status      PostStatus  @default(DRAFT)

  scheduledAt    DateTime? // The intended publish time
  publishedAt    DateTime? // When it actually went out
  timezone       String    @default("UTC")
  isAutoSchedule Boolean   @default(false) // If true, uses QueueSlot

  isUrgent    Boolean @default(false)

  errorMessage String? // General error (if all failed)
  maxRetries   Int     @default(3)
  retryCount   Int     @default(0)

  // 🧵 THREADS (X/Twitter)
  parentPostId String?
  parentPost   Post?   @relation("PostThread", fields: [parentPostId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  childPosts   Post[]  @relation("PostThread")

  destinations PostDestination[]
  campaignId   String?
  campaign     Campaign?         @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  approvals    PostApproval[]

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author    User?     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  isAiGenerated Boolean @default(false)
  aiPrompt      String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, status, scheduledAt])
  @@index([campaignId])
}

model PostDestination {
  id              String @id @default(cuid())
  postId          String
  socialProfileId String // The specific account (Nike FB, Nike IG)

  // 🎨 OVERRIDES
  // If null, falls back to Post.content
  contentOverride String? @db.Text

  // 🚦 STATUS
  status         PublishStatus @default(SCHEDULED)
  platformPostId String? // The ID from FB/LinkedIn after posting
  platformUrl    String? // Link to the live post
  errorMessage   String?

  post    Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  profile SocialProfile @relation(fields: [socialProfileId], references: [id], onDelete: Cascade)

  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())
  publishedAt DateTime?

  metadata Json?

  postAnalyticsSnapshots PostAnalyticsSnapshot[]

  comments Comment[]

  @@unique([postId, socialProfileId])
  @@index([status])
  @@index([socialProfileId, createdAt])
  @@index([socialProfileId, status, createdAt])
}

// 🖼️ Explicit Join for Media Ordering
model PostMedia {
  id          String @id @default(cuid())
  postId      String
  mediaFileId String
  order       Int    @default(0) // 0 = Cover image, 1 = Next, etc.

  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  mediaFile MediaFile @relation(fields: [mediaFileId], references: [id], onDelete: Cascade)

  @@unique([postId, mediaFileId])
  @@index([postId, order])
}

// ==========================================
// 3. MEDIA LIBRARY (Optimized)
// ==========================================

model MediaFolder {
  id          String  @id @default(cuid())
  workspaceId String
  name        String
  parentId    String?

  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent    MediaFolder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children  MediaFolder[] @relation("FolderHierarchy")
  files     MediaFile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, parentId, name])
}

model MediaFile {
  id          String  @id @default(cuid())
  workspaceId String
  userId      String
  folderId    String?

  userAvatar User? @relation("UserAvatar")

  filename     String
  originalName String
  mimeType     String // image/jpeg, video/mp4
  size         BigInt
  url          String // Cloudinary/S3 URL
  publicId     String // For Cloudinary deletion
  thumbnailUrl String?

  width    Int? // Important for aspect ratio checks
  height   Int?
  duration Int? // In seconds (for Videos)

  // 🤖 AI METADATA (Embedded)
  // Just flags to help you filter "Show me AI images" in the library
  isAiGenerated Boolean @default(false)
  aiProvider    String? // "dall-e-3", "midjourney"
  aiPrompt      String? @db.Text // Store the prompt so user can "Reuse" it

  postUsage PostMedia[] // Relation to posts

  brandKit BrandKit? @relation("BrandKitLogo")

  folder    MediaFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ticketId String?
  ticket   Ticket? @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  ticketCommentId String?
  ticketComment   TicketComment? @relation(fields: [ticketCommentId], references: [id], onDelete: SetNull)

  @@index([workspaceId, mimeType])
}

// ==========================================
// 4. QUEUE & SCHEDULING RULES
// ==========================================

model QueueSlot {
  id          String @id @default(cuid())
  workspaceId String

  platform Platform?

  dayOfWeek Int
  time      String // "09:00" (24h format)

  isActive Boolean @default(true)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

// ==========================================
// 6. CONTENT TEMPLATES
// ==========================================

model ContentTemplate {
  id             String  @id @default(cuid())
  organizationId String?
  userId         String

  name        String
  description String?

  // Usage Metadata
  platform    Platform
  contentType ContentType
  category    TemplateCategory
  tags        String[]

  content Json // Structured content

  isPublic   Boolean @default(false)
  usageCount Int     @default(0)

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  favorites UserFavoriteTemplate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, platform])
  @@index([isPublic, category])
}

model UserFavoriteTemplate {
  id         String @id @default(cuid())
  userId     String
  templateId String

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  template ContentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([userId, templateId])
}

model PublishingMetric {
  id             String   @id @default(uuid())
  organizationId String
  platform       Platform
  success        Boolean
  errorMessage   String? // optional, only filled on failure
  timestamp      DateTime @default(now())

  // relations
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, platform, timestamp])
}

// The Plan Model (Your Tiers)
model Plan {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  tier        PlanTier @default(CREATOR)

  // BILLING MAPPING
  paystackPlanCodeNgn String? @unique
  paystackPlanCodeUsd String? @unique

  // PRICING (Display purposes)
  priceNgn Decimal         @default(0.00) @db.Decimal(10, 2)
  priceUsd Decimal         @default(0.00) @db.Decimal(10, 2)
  interval BillingInterval

  // --- LIMITS (The "Guards") ---

  // Rocket Plan specific: "Up to 5 workspaces"
  maxWorkspaces Int @default(1)

  // "Up to 3 social profiles" (Creator) vs "4 per workspace" (Rocket)
  maxSocialProfilesPerWorkspace Int @default(3)

  // "1 user" (Creator) vs "Unlimited" (Rocket - set to -1 or 9999)
  maxTeamMembers Int @default(1)

  // AI Usage Limits (Credits per month)
  monthlyAiCredits Int @default(100)

  // --- FEATURES (Flags) ---
  // JSON stores boolean flags: 
  // { "canRemoveBranding": true, "hasAdvancedAnalytics": true, "hasApprovalWorkflow": true }
  features Json @default("{}")

  isActive      Boolean        @default(true)
  subscriptions Subscription[]

  // list allowed platforms
  allowedPlatforms Platform[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// The Active Subscription
model Subscription {
  id String @id @default(cuid())

  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])

  planId String
  plan   Plan   @relation(fields: [planId], references: [id])

  // STATUS & PERIOD
  status             String   @default("active") // "active", "past_due", "canceled", "incomplete"
  isActive           Boolean
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean  @default(false)

  // --- PAYSTACK SPECIFIC FIELDS (NGN) ---
  paystackSubscriptionCode String? // "SUB_vsyqdmlzble3uii"
  paystackEmailToken       String? // "otk_54321" (For one-click actions)
  paystackAuthCode         String? // "AUTH_8dfhgpkv" (CRITICAL: Used to charge card for renewal)

  // --- ENTERPRISE MAGIC: CUSTOM LIMITS ---
  // If this is set, these numbers OVERRIDE the Plan defaults.
  // Example: { "maxWorkspaces": 10, "maxTeamMembers": 50 }
  // Logic: const limit = sub.customLimits?.maxWorkspaces || plan.maxWorkspaces
  customLimits Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Transaction History (Invoices)
model Transaction {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  amount   Decimal @db.Decimal(10, 2)
  currency String
  status   String // successful, failed, abandoned

  txRef String @unique

  // PROVIDER DETAILS
  provider     String // "PAYSTACK"
  providerTxId String // Paystack "reference"

  // Detailed breakdown
  metadata Json? // Store extra JSON from webhook (e.g. IP address, card type)

  paymentDate DateTime @default(now())

  // Link to a specific subscription period if needed for auditing
  subscriptionId String?
  invoiceUrl     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BrandKit {
  id          String  @id @default(cuid())
  workspaceId String  @unique
  name        String  @default("Our Brand")
  handle      String?

  // Visual identity - flexible JSON structure
  // Changed: logoUrl becomes logoId
  logoId String?    @unique // Unique if one media file is only one logo
  logo   MediaFile? @relation("BrandKitLogo", fields: [logoId], references: [id], onDelete: SetNull)
  colors Json? // { primary: "#1E40AF", secondary: "#F59E0B", ... }

  // Brand voice
  brandVoice String? @db.VarChar(500)
  tone       String? // Could use enum or free text
  guidelines Json? // Additional brand guidelines

  // Status
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  //ContentTemplate      ContentTemplate[]

  @@index([isActive])
}

model AiGeneration {
  id String @id @default(cuid())

  organizationId String
  workspaceId    String

  // Use enums (cleaner than strings)
  type    AiType // TEXT | IMAGE
  feature AiFeature

  provider AiProvider
  model    String

  // Inputs/outputs (optional but extremely useful)
  prompt String? @db.Text
  input  Json?
  output Json?

  // Usage/cost
  inputTokens  Int?
  outputTokens Int?
  costUsd      Float?
  creditCost   Int?

  // Link to other domain objects
  brandKitId String?
  postId     String?

  metadata Json?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([postId])
  @@index([brandKitId])
}

model InboxConversation {
  id          String @id @default(cuid())
  workspaceId String

  // Which social profile owns this conversation?
  socialProfileId String
  socialProfile   SocialProfile @relation(fields: [socialProfileId], references: [id])

  // The ID of the thread on the external platform
  externalId String

  // The person we are talking to
  contactId String
  contact   SocialContact @relation(fields: [contactId], references: [id])

  // Workflow States
  status   ConversationStatus   @default(UNASSIGNED)
  priority ConversationPriority @default(NORMAL)

  // Assignment (Linked to your Org/Workspace Member)
  assignedMemberId String?
  assignedMember   WorkspaceMember? @relation("ConversationAssignee", fields: [assignedMemberId], references: [id])

  // Optional but great for UI clutter
  archivedAt    DateTime?
  snoozedUntil  DateTime?
  // Metadata for the UI list
  lastMessageAt DateTime
  snippet       String? // Preview of the last message

  messages   InboxMessage[]
  readStates ConversationReadState[]

  // Thread IDs are only guaranteed unique per connected account/page
  @@unique([socialProfileId, externalId])
  @@index([workspaceId, lastMessageAt])
  @@index([assignedMemberId])
}

model InboxMessage {
  id             String            @id @default(cuid())
  conversationId String
  conversation   InboxConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  // 1. The Internal ID (Always required)
  clientMessageId String

  // 2. The External ID (Optional, filled in when Meta gives it to us)
  providerMessageId String?

  content   String           @db.Text
  direction MessageDirection

  // Attachments (Images/Videos)
  attachments InboxMessageAttachment[]

  deliveryStatus DeliveryStatus? // Nullable, as inbound messages don't need this

  // Error Debugging
  errorCode    String? // e.g., "OAuthException", "RateLimit"
  errorMessage String? @db.Text

  // When the platform actually processed it (differs from your DB createdAt)
  providerTimestamp DateTime?

  createdAt  DateTime @default(now())
  senderName String? // Snapshot of name at time of sending

  authorMemberId String?
  authorMember   WorkspaceMember? @relation(fields: [authorMemberId], references: [id])

  @@unique([conversationId, providerMessageId])
}

model SocialContact {
  id          String @id @default(cuid())
  workspaceId String

  platform   Platform
  externalId String // Their User ID on Instagram/LinkedIn

  username  String
  avatarUrl String?

  conversations InboxConversation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@unique([workspaceId, platform, externalId])
}

model InboxMessageAttachment {
  id        String       @id @default(cuid())
  messageId String
  message   InboxMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  type AttachmentType // Enum: IMAGE, VIDEO, AUDIO, DOCUMENT, STICKER
  url  String         @db.Text // Original CDN URL

  // Storage for your own S3/Cloudfront mirror (when the original expires)
  proxyUrl     String? @db.Text
  thumbnailUrl String? @db.Text

  mimeType      String? // e.g., 'image/jpeg'
  fileSizeBytes Int?

  // For any platform-specific weirdness (like Instagram Story Reply contexts)
  meta Json?

  @@index([messageId])
}

model ConversationReadState {
  id String @id @default(cuid())

  conversationId String
  conversation   InboxConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  memberId String
  member   WorkspaceMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  // When did this specific agent last look at this thread?
  lastReadAt DateTime @default(now())

  // One read state per agent per conversation
  @@unique([conversationId, memberId])
}

model Notification {
  id String @id @default(cuid())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Who receives it (use User or WorkspaceMember depending on your design)
  memberId String
  member   WorkspaceMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  type NotificationType

  // Display content
  title String
  body  String? @db.Text

  // Structured payload (postId, conversationId, etc.)
  data Json?

  // Optional deep-link target (frontend convenience)
  link String?

  // Read tracking
  readAt DateTime?

  createdAt DateTime @default(now())

  dedupeKey String?

  @@unique([memberId, dedupeKey])
  @@index([workspaceId, createdAt])
  @@index([memberId, readAt])
}

model Comment {
  id          String @id @default(cuid())
  workspaceId String
  profileId   String

  externalPostId    String
  externalCommentId String

  platform  Platform
  direction Direction     @default(INBOUND)
  status    CommentStatus @default(VISIBLE)

  // 4. Safer Sender Tracking
  senderExternalId String // The raw ID from the network
  senderPlatformId String? // Page-scoped user ID (PSID) 
  senderName       String?
  senderAvatarUrl  String? @db.Text

  content  String  @db.Text
  mediaUrl String? @db.Text

  parentId String?
  parent   Comment?  @relation("CommentToComment", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies  Comment[] @relation("CommentToComment")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isResolved Boolean   @default(false)
  resolvedAt DateTime?

  // 2. THE UPGRADE: Relate the resolver to your User model
  resolvedById String?
  resolvedBy   User?   @relation(fields: [resolvedById], references: [id], onDelete: SetNull)

  postDestinationId String? // Optional: Null if the post wasn't published via Rooli
  postDestination   PostDestination? @relation(fields: [postDestinationId], references: [id], onDelete: Cascade)

  // Relationships
  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  profile   SocialProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  authorMemberId String?
  authorMember   WorkspaceMember? @relation(fields: [authorMemberId], references: [id])

  @@unique([platform, externalCommentId])
  @@index([workspaceId, isResolved, createdAt(sort: Desc)])
  @@index([externalPostId, createdAt(sort: Desc)])
  @@index([parentId])
}

model PlatformRateLimitLog {
  id              String   @id @default(cuid())
  platform        Platform
  socialAccountId String
  requestType     String // e.g. "post", "dm", "comment"
  consumedAt      DateTime @default(now())
  windowStart     DateTime
  windowEnd       DateTime
  status          String // "allowed" | "blocked"

  @@index([platform, socialAccountId, windowStart, windowEnd])
}

// ==========================================
// 📊 POST ANALYTICS (OMNICHANNEL BASE)
// ==========================================
model PostAnalyticsSnapshot {
  id                String @id @default(cuid())
  postDestinationId String

  day       DateTime @db.Date // Normalized day (e.g., 2026-03-04)
  fetchedAt DateTime @default(now())

  // --- THE OMNICHANNEL CORE ---
  // Only metrics shared across ALL platforms go here.
  likes           Int @default(0)
  comments        Int @default(0)
  impressions     Int @default(0) // Total views
  reach           Int @default(0) // Unique viewers (if platform provides it)
  engagementCount Int @default(0) // Aggregated sum for quick dashboard sorting

  postDestination PostDestination @relation(fields: [postDestinationId], references: [id], onDelete: Cascade)

  // --- PLATFORM SPECIFIC RELATIONS ---
  twitterStats   TwitterPostStats?
  linkedInStats  LinkedInPostStats?
  facebookStats  FacebookPostStats?
  instagramStats InstagramPostStats?
  tiktokStats    TikTokPostStats?

  @@unique([postDestinationId, day])
  @@index([postDestinationId, day])
}

// ==========================================
// 🐦 TWITTER POST STATS
// ==========================================
model TwitterPostStats {
  id         String                @id @default(cuid())
  snapshotId String                @unique
  snapshot   PostAnalyticsSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  retweets   Int @default(0)
  quotes     Int @default(0)
  bookmarks  Int @default(0)
  videoViews Int @default(0)
}

// ==========================================
// 💼 LINKEDIN POST STATS
