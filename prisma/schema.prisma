  snapshotId String                @unique
  snapshot   PostAnalyticsSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  // Shared metrics (Available to both Personal & Org)
  reposts Int @default(0)

  // Organization Only (Make these optional/nullable)
  clicks     Int?
  videoViews Int?
}

// ==========================================
// 📘 FACEBOOK POST STATS
// ==========================================
model FacebookPostStats {
