/// ===============================
/// AUDIT LOGS 
/// ===============================

model AuditLog {
  id             String @id @default(cuid())
  organizationId String

  actorUserId   String?
  actorMemberId String? // better than userId-only for org context

  action       AuditAction
  resourceType AuditResourceType
  resourceId   String?
  details      Json?

  ipAddress String?
  userAgent String?

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUser    User?               @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  actorMember  OrganizationMember? @relation(fields: [actorMemberId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([action, resourceType])
}

/// ===============================
/// APPROVALS 
/// ===============================

model PostApproval {
  id     String @id @default(cuid())
  postId String

  requesterId String
  approverId  String?

  status ApprovalStatus @default(PENDING)
  notes  String?        @db.Text

  requestedAt DateTime  @default(now())
  reviewedAt  DateTime?

  post      Post  @relation(fields: [postId], references: [id], onDelete: Cascade)
  requester User  @relation("ApprovalRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  approver  User? @relation("ApprovalApprover", fields: [approverId], references: [id], onDelete: SetNull)

  @@index([postId, status])
  @@index([requesterId])
  @@index([approverId])
}

model PostingSchedule {
  id             String         @id @default(cuid())
  organizationId String
  platform       Platform
  timezone       String         @default("UTC")
  isActive       Boolean        @default(true)
  lastUpdated    DateTime       @default(now())
  source         ScheduleSource @default(AI_RECOMMENDATION)
  optimalTimes   Json // { monday: [9, 14, 18], tuesday: [10, 16], ... }
  excludedDates  String[] // ["2024-12-25", "2024-01-01"]
  maxPostsPerDay Int            @default(5)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, platform])
  @@index([isActive, platform])
}

model Ticket {
  id          String @id @default(cuid())
  workspaceId String

  // Custom ticket number (e.g., Ticket #1042)
  ticketNumber Int @unique @default(autoincrement())

  title       String
  description String         @db.Text
  status      TicketStatus   @default(OPEN)
  category    TicketCategory @default(OTHER)
  priority    TicketPriority @default(MEDIUM)

  // 1. THE REQUESTER: The Rooli user who needs help
  // We link this to WorkspaceMember so you know exactly which workspace they belong to.
  requesterId String
  requester   WorkspaceMember @relation("TicketRequester", fields: [requesterId], references: [id])

  // 2. THE ASSIGNEE: The Rooli Admin/Support Agent fixing the issue
  // We link this directly to the User model, assuming your support agents are global users with an "ADMIN" role.
  assigneeId String?
  assignee   User?   @relation("TicketAssignee", fields: [assigneeId], references: [id])

  // --- RELATIONS ---
  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  mediaFiles MediaFile[] // Reusing your media files instead of custom attachments

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  closedAt  DateTime?

  comments TicketComment[]

  @@index([workspaceId, status])
  @@index([assigneeId, status])
}

model TicketComment {
  id       String @id @default(cuid())
  ticketId String

  // Who wrote this comment? (We link directly to the User model)
  authorUserId String
  author       User   @relation(fields: [authorUserId], references: [id])

  // Is this comment from the customer or from Rooli Support?
  isFromSupport Boolean @default(false)

  // Can the customer see this, or is it a secret note for other Rooli admins?
  isInternal Boolean @default(false)

  content String @db.Text

  // --- RELATIONS ---
  ticket     Ticket      @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  mediaFiles MediaFile[]

  createdAt DateTime @default(now())

  @@index([ticketId])
}

