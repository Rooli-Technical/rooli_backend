}

// Store daily aggregate data for the Account/Page itself
// ==========================================
// 📈 ACCOUNT ANALYTICS (OMNICHANNEL BASE)
// ==========================================
model AccountAnalytics {
  id              String   @id @default(cuid())
  socialProfileId String
  date            DateTime @db.Date

  // --- THE OMNICHANNEL CORE ---
  // Growth
  followersTotal  Int @default(0)
  followersGained Int @default(0)
  followersLost   Int @default(0)

  // Reach & Traffic
  impressions  Int @default(0)
  reach        Int @default(0)
  profileViews Int @default(0)
  clicks       Int @default(0) // Aggregated clicks across the profile

  // Overall Engagement
  engagementCount Int @default(0) // Sum of all interactions that day

  socialProfile SocialProfile @relation(fields: [socialProfileId], references: [id], onDelete: Cascade)

  // --- PLATFORM SPECIFIC RELATIONS ---
  twitterStats   TwitterAccountStats?
  linkedInStats  LinkedInAccountStats?
  facebookStats  FacebookAccountStats?
  instagramStats InstagramAccountStats?
  tiktokStats    TikTokAccountStats?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([socialProfileId, date])
  @@index([socialProfileId, date])
  @@index([date])
}

// ==========================================
// 🐦 TWITTER ACCOUNT STATS
// ==========================================
model TwitterAccountStats {
  id               String           @id @default(cuid())
  accountStatsId   String           @unique
  accountAnalytics AccountAnalytics @relation(fields: [accountStatsId], references: [id], onDelete: Cascade)

