<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="x-apple-disable-message-reformatting">
  <title>You've been invited to Rooli</title>
  <style>
    @media only screen and (max-width: 620px) {
      .container { width: 100% !important; border-radius: 0 !important; }
      .px { padding-left: 24px !important; padding-right: 24px !important; }
    }
    a { color: #0B1F3A; }
  </style>
</head>
<body style="margin:0; padding:0; background-color:#F4F5F7; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Arial,sans-serif; color:#3C4858;">
  <div style="display:none; max-height:0; overflow:hidden; opacity:0; mso-hide:all;">{{inviterName}} invited you to {{contextName}} on Rooli.</div>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#F4F5F7;">
    <tr>
      <td align="center" style="padding: 40px 16px;">
        <table role="presentation" class="container" width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px; width:100%; background-color:#ffffff; border-radius:12px; border:1px solid #E6E8EC;">

          <tr>
            <td class="px" style="padding: 32px 40px 0 40px;">
              <p style="margin:0; font-size:18px; font-weight:700; letter-spacing:-0.2px; color:#0B1F3A;">Rooli</p>
            </td>
          </tr>

          <tr>
            <td class="px" style="padding: 24px 40px 8px 40px;">
              <h1 style="margin:0 0 16px 0; font-size:22px; line-height:1.3; font-weight:600; color:#0B1F3A;">
                {{#if isWorkspaceInvite}}You've been added to {{contextName}}{{else}}You're invited to join {{contextName}}{{/if}}
              </h1>
              <p style="margin:0 0 16px 0; font-size:15px; line-height:1.65; color:#3C4858;">
                <strong style="color:#0B1F3A;">{{inviterName}}</strong> invited you to join
                {{#if isWorkspaceInvite}}the <strong style="color:#0B1F3A;">{{contextName}}</strong> workspace{{else}}<strong style="color:#0B1F3A;">{{contextName}}</strong>{{/if}}
                on Rooli as a <strong style="color:#0B1F3A;">{{roleName}}</strong>.
              </p>
            </td>
          </tr>

          {{#if message}}
          <tr>
            <td class="px" style="padding: 8px 40px 8px 40px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#F8F9FB; border-left:3px solid #0B1F3A; border-radius:6px;">
                <tr>
                  <td style="padding: 14px 18px;">
                    <p style="margin:0; font-size:14px; line-height:1.6; color:#3C4858; font-style:italic;">"{{message}}"</p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          {{/if}}

          <tr>
            <td class="px" style="padding: 16px 40px 8px 40px;">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="border-radius:8px; background-color:#0B1F3A;">
                    <a href="{{invitationUrl}}" target="_blank" style="display:inline-block; padding:13px 28px; font-size:15px; font-weight:600; color:#ffffff; text-decoration:none; border-radius:8px;">
                      Accept invitation
                    </a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <tr>
            <td class="px" style="padding: 16px 40px 32px 40px;">
              <p style="margin:0; font-size:13px; line-height:1.6; color:#7A8599;">
                This invitation expires in 7 days. If you weren't expecting this email, you can safely ignore it.
              </p>
            </td>
          </tr>

          <tr>
            <td style="border-top:1px solid #E6E8EC;"></td>
          </tr>

          <tr>
            <td class="px" style="padding: 24px 40px;">
              <p style="margin:0; font-size:12px; line-height:1.6; color:#7A8599; text-align:center;">
                &copy; {{year}} Rooli, Inc. All rights reserved.
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
