<html>
  <head>
    <meta charset='utf-8' />
    <title>Connection Expiring Soon</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        background-color: #f9fafb;
        padding: 20px;
        color: #111827;
      }
      .container {
        max-width: 600px;
        margin: 0 auto;
        background: #ffffff;
        border-radius: 8px;
        padding: 24px;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.08);
      }
      h2 {
        color: #1f2937;
      }
      p {
        line-height: 1.6;
      }
      .alert-box {
        padding: 12px;
        background: #fffbeb;
        border-left: 4px solid #f59e0b;
        margin: 20px 0;
      }
      .button {
        display: inline-block;
        margin-top: 20px;
        padding: 12px 20px;
        background-color: #2563eb;
        color: #ffffff;
        text-decoration: none;
        border-radius: 6px;
        font-weight: bold;
      }
      .footer {
        margin-top: 30px;
        font-size: 12px;
        color: #6b7280;
        text-align: center;
      }
    </style>
  </head>
  <body>
    <div class='container'>
      <h2>Action Required: Reconnect {{platform}}</h2>

      <p>Hello {{userName}},</p>

      <div class='alert-box'>
        <p style='margin: 0;'>
          Your connection to
          <strong>{{platform}}</strong>
          ({{platformUsername}}) is set to expire in 7 days due to the
          platform's security policies.
        </p>
      </div>

      <p>
        To ensure your scheduled posts and omnichannel inbox continue to work
        without interruption, please reconnect your account.
      </p>

      <a
        href='{{integrationsUrl}}'
        class='button'
        style='color: #ffffff;'
      >Reconnect {{platform}} Now</a>

      <div class='footer'>
        <p>If you have already reconnected, you can safely ignore this email.</p>
        <p>© {{year}} Rooli. All rights reserved.</p>
      </div>
    </div>
  </body>
</html>