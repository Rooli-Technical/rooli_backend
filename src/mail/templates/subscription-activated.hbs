<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="x-apple-disable-message-reformatting">
  <title>Your Rooli subscription is active</title>
  <style>
    @media only screen and (max-width: 620px) {
      .container { width: 100% !important; border-radius: 0 !important; }
      .px { padding-left: 24px !important; padding-right: 24px !important; }
    }
    a { color: #0B1F3A; }
  </style>
</head>
<body style="margin:0; padding:0; background-color:#F4F5F7; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Arial,sans-serif; color:#3C4858;">
  <div style="display:none; max-height:0; overflow:hidden; opacity:0; mso-hide:all;">Your {{planName}} plan is now active. Receipt details inside.</div>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#F4F5F7;">
    <tr>
      <td align="center" style="padding: 40px 16px;">
        <table role="presentation" class="container" width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px; width:100%; background-color:#ffffff; border-radius:12px; border:1px solid #E6E8EC;">

          <tr>
            <td class="px" style="padding: 32px 40px 0 40px;">
              <p style="margin:0; font-size:18px; font-weight:700; letter-spacing:-0.2px; color:#0B1F3A;">Rooli</p>
            </td>
          </tr>

          <tr>
            <td class="px" style="padding: 24px 40px 8px 40px;">
              <h1 style="margin:0 0 16px 0; font-size:22px; line-height:1.3; font-weight:600; color:#0B1F3A;">Your subscription is active</h1>
              <p style="margin:0 0 8px 0; font-size:15px; line-height:1.65; color:#3C4858;">
                Hi {{userName}}, thanks for upgrading <strong style="color:#0B1F3A;">{{orgName}}</strong>. Here's a summary of your purchase.
              </p>
            </td>
          </tr>

          <tr>
            <td class="px" style="padding: 16px 40px 8px 40px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#F8F9FB; border:1px solid #E6E8EC; border-radius:8px;">
                <tr>
                  <td style="padding: 16px 20px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="padding: 6px 0; font-size:14px; color:#7A8599;">Plan</td>
                        <td align="right" style="padding: 6px 0; font-size:14px; font-weight:600; color:#0B1F3A;">{{planName}}</td>
                      </tr>
                      <tr>
                        <td style="padding: 6px 0; font-size:14px; color:#7A8599;">Billing cycle</td>
                        <td align="right" style="padding: 6px 0; font-size:14px; font-weight:600; color:#0B1F3A;">{{billingInterval}}</td>
                      </tr>
                      <tr>
                        <td style="padding: 6px 0; font-size:14px; color:#7A8599;">Amount paid</td>
                        <td align="right" style="padding: 6px 0; font-size:14px; font-weight:600; color:#0B1F3A;">{{currency}} {{amount}}</td>
                      </tr>
                      <tr>
                        <td style="padding: 6px 0 0 0; font-size:14px; color:#7A8599; border-top:1px solid #E6E8EC;">Next billing date</td>
                        <td align="right" style="padding: 6px 0 0 0; font-size:14px; font-weight:600; color:#0B1F3A; border-top:1px solid #E6E8EC;">{{nextBillingDate}}</td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <tr>
            <td class="px" style="padding: 24px 40px 8px 40px;">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="border-radius:8px; background-color:#0B1F3A;">
                    <a href="{{billingUrl}}" target="_blank" style="display:inline-block; padding:13px 28px; font-size:15px; font-weight:600; color:#ffffff; text-decoration:none; border-radius:8px;">
                      View billing
                    </a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <tr>
            <td class="px" style="padding: 16px 40px 32px 40px;">
              <p style="margin:0; font-size:13px; line-height:1.6; color:#7A8599;">
                Questions about your invoice? Reply to this email or contact <a href="mailto:support@rooli.com" style="color:#0B1F3A;">support@rooli.com</a>.
              </p>
            </td>
          </tr>

          <tr>
            <td style="border-top:1px solid #E6E8EC;"></td>
          </tr>

          <tr>
            <td class="px" style="padding: 24px 40px;">
              <p style="margin:0; font-size:12px; line-height:1.6; color:#7A8599; text-align:center;">
                &copy; {{year}} Rooli, Inc. All rights reserved.
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
